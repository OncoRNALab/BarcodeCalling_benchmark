   "source": [
    "# Load 21K results from previous experiments\n",
    "print(\"Loading 21K results from previous experiments...\")\n",
    "results_21k = load_21k_results_from_previous()\n",
    "\n",
    "# Load 42K and 85K results from new parameter sweep\n",
    "print(\"\\nLoading 42K and 85K results from new parameter sweep...\")\n",
    "all_results = []\n",
    "\n",
    "for tool_name, tool_config in TOOLS.items():\n",
    "    for barcode_count in [42000, 85000]:  # Only load 42K and 85K here\n",
    "        for barcode_length in BARCODE_LENGTHS:\n",
    "            for threshold in tool_config['thresholds']:\n",
    "                result = load_results_for_tool(tool_name, barcode_count, barcode_length, threshold)\n",
    "                if result:\n",
    "                    all_results.append(result)\n",
    "\n",
    "print(f\"Loaded {len(all_results)} results from new parameter sweep\")\n",
    "\n",
    "# Combine 21K and new results\n",
    "if len(results_21k) > 0:\n",
    "    df_21k = pd.DataFrame(results_21k)\n",
    "    df_new = pd.DataFrame(all_results) if len(all_results) > 0 else pd.DataFrame()\n",
    "    \n",
    "    # Combine dataframes\n",
    "    if len(df_new) > 0:\n",
    "        df_all = pd.concat([df_21k, df_new], ignore_index=True)\n",
    "    else:\n",
    "        df_all = df_21k\n",
    "else:\n",
    "\n",
    "    df_all = pd.DataFrame(all_results)    print(\"\\n⚠️  No results loaded. Jobs may still be running or results files not yet generated.\")\n",
