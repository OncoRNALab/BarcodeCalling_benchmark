    "\n",
    "        sample_id = f\"RB_{count_label}_{barcode_length}nt_t100_n{threshold}\"    print(\"\\n✓ Successfully loaded test result from new parameter sweep\")\n",
    "\n",
    "        results_dir = RESULTS_PATH / \"randombarcodes\" / f\"{count_label}_{barcode_length}nt\" / \"results\" / f\"t100_n{threshold}\"if test_result:\n",
    "\n",
    "    elif tool_name == 'quik':test_result = load_results_for_tool('randombarcodes', 42000, 28, 5)\n",
    "\n",
    "        sample_id = f\"QUIK_{count_label}_{barcode_length}nt_4mer_r{threshold}\"\n",
    "\n",
    "        results_dir = RESULTS_PATH / \"quik\" / f\"{count_label}_{barcode_length}nt\" / \"results\" / f\"4mer_r{threshold}\"    print(\"⚠️  No 21K results loaded\")\n",
    "\n",
    "    elif tool_name == 'columba':else:\n",
    "\n",
    "        sample_id = f\"Columba_{count_label}_{barcode_length}nt_I{threshold}\"    print(f\"  Sample: {results_21k[0].get('sample_id', 'N/A')}\")\n",
    "\n",
    "        results_dir = RESULTS_PATH / \"columba\" / f\"{count_label}_{barcode_length}nt\" / \"results\" / f\"I{threshold}\"    print(\"✓ Successfully loaded 21K results from previous experiments\")\n",
    "\n",
    "    else:if len(results_21k) > 0:\n",
    "\n",
    "        return Noneresults_21k = load_21k_results_from_previous()\n",
    "\n",
    "    print(\"Testing data loading...\\n\")\n",
    "\n",
    "    # Look for results files# Test loading\n",
    "\n",
    "    summary_file = results_dir / f\"{sample_id}_summary.txt\"\n",
    "\n",
    "    \n",
    "\n",
    "    if not summary_file.exists():    return results\n",
    "\n",
