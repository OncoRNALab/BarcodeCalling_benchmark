    "def load_21k_results_from_previous():\n",
    "    \"\"\"\n",
    "    Load 21K barcode results from previous parameter sweep experiments.\n",
    "    Filters: RandomBarcodes (ntriage=100), QUIK (strategy='4mer'), Columba (all)\n",
    "    Only includes thresholds that match our current sweep parameters.\n",
    "    \n",
    "    Returns:\n",
    "        list: List of result dictionaries\n",
    "    \"\"\"\n",
    "    results_21k = []\n",
    "    \n",
    "    # Load 28nt results\n",
    "    if PREVIOUS_RESULTS_28NT.exists():\n",
    "        df_28nt = pd.read_csv(PREVIOUS_RESULTS_28NT)\n",
    "        \n",
    "        # Filter by tool and configuration\n",
    "        # RandomBarcodes: ntriage=100, nthresh in [5,6,7,8,9]\n",
    "        rb_28 = df_28nt[\n",
    "            (df_28nt['tool'] == 'RandomBarcodes') & \n",
    "            (df_28nt['ntriage'] == 100) &\n",
    "            (df_28nt['nthresh'].isin([5, 6, 7, 8, 9]))\n",
    "        ].copy()\n",
    "        \n",
    "        # QUIK: strategy='4mer', rejection_threshold in [5,6,7,8,9]\n",
    "        quik_28 = df_28nt[\n",
    "            (df_28nt['tool'] == 'QUIK') & \n",
    "            (df_28nt['strategy'] == '4mer') &\n",
    "            (df_28nt['rejection_threshold'].isin([5, 6, 7, 8, 9]))\n",
    "        ].copy()\n",
    "        \n",
    "        # Columba: identity_threshold in [77,78,79,80,81,82]\n",
    "        # Note: Old data may not have all these thresholds, just use what's available\n",
    "        columba_28 = df_28nt[\n",
    "            (df_28nt['tool'] == 'Columba') &\n",
    "            (df_28nt['identity_threshold'].isin([77, 78, 79, 80, 81, 82]))\n",
    "        ].copy()\n",
    "        \n",
    "        # Combine and add metadata\n",
    "        df_28nt_filtered = pd.concat([rb_28, quik_28, columba_28], ignore_index=True)\n",
    "        df_28nt_filtered['barcode_count'] = 21000\n",
    "        df_28nt_filtered['barcode_length'] = 28\n",
    "        \n",
    "        # Standardize threshold column\n",
    "        df_28nt_filtered['threshold'] = df_28nt_filtered.apply(\n",
    "            lambda row: row['nthresh'] if pd.notna(row['nthresh']) \n",
    "            else (row['rejection_threshold'] if pd.notna(row['rejection_threshold']) \n",
    "            else row['identity_threshold']), axis=1\n",
    "        )\n",
    "        \n",
    "        results_21k.extend(df_28nt_filtered.to_dict('records'))\n",
    "        print(f\"  28nt: {len(df_28nt_filtered)} results (RB:{len(rb_28)}, QUIK:{len(quik_28)}, Columba:{len(columba_28)})\")\n",
    "    \n",
    "    # Load 36nt results\n",
    "    if PREVIOUS_RESULTS_36NT.exists():\n",
    "        df_36nt = pd.read_csv(PREVIOUS_RESULTS_36NT)\n",
    "        \n",
    "        # Filter by tool and configuration\n",
    "        # RandomBarcodes: ntriage=100, nthresh in [5,6,7,8,9]\n",
    "        rb_36 = df_36nt[\n",
    "            (df_36nt['tool'] == 'RandomBarcodes') & \n",
    "            (df_36nt['ntriage'] == 100) &\n",
    "            (df_36nt['nthresh'].isin([5, 6, 7, 8, 9]))\n",
    "        ].copy()\n",
    "        \n",
    "        # QUIK: strategy='4mer', rejection_threshold in [5,6,7,8,9]\n",
    "        quik_36 = df_36nt[\n",
    "            (df_36nt['tool'] == 'QUIK') & \n",
    "            (df_36nt['strategy'] == '4mer') &\n",
    "            (df_36nt['rejection_threshold'].isin([5, 6, 7, 8, 9]))\n",
    "        ].copy()\n",
    "        \n",
    "        # Columba: identity_threshold in [77,78,79,80,81,82]\n",
    "        columba_36 = df_36nt[\n",
    "            (df_36nt['tool'] == 'Columba') &\n",
    "            (df_36nt['identity_threshold'].isin([77, 78, 79, 80, 81, 82]))\n",
    "        ].copy()\n",
    "        \n",
    "        # Combine and add metadata\n",
    "        df_36nt_filtered = pd.concat([rb_36, quik_36, columba_36], ignore_index=True)\n",
    "        df_36nt_filtered['barcode_count'] = 21000\n",
    "        df_36nt_filtered['barcode_length'] = 36\n",
    "        \n",
    "        # Standardize threshold column\n",
    "        df_36nt_filtered['threshold'] = df_36nt_filtered.apply(\n",
    "            lambda row: row['nthresh'] if pd.notna(row['nthresh']) \n",
    "            else (row['rejection_threshold'] if pd.notna(row['rejection_threshold']) \n",
    "            else row['identity_threshold']), axis=1\n",
    "        )\n",
    "        \n",
    "        results_21k.extend(df_36nt_filtered.to_dict('records'))\n",
    "        print(f\"  36nt: {len(df_36nt_filtered)} results (RB:{len(rb_36)}, QUIK:{len(quik_36)}, Columba:{len(columba_36)})\")\n",
    "    \n",
    "    print(f\"Total 21K results loaded: {len(results_21k)}\")\n",
    "    return results_21k\n",
    "\n",
    "\n",
    "def load_results_for_tool(tool_name, barcode_count, barcode_length, threshold):\n",
    "    \"\"\"\n",
    "    Load results for 42K/85K from new parameter sweep.\n",
    "    \n",
    "    Returns:\n",
    "        dict: Results containing metrics, or None if not found\n",
    "    \"\"\"\n",
    "    count_label = f\"{barcode_count//1000}K\"\n",
    "\n",
    "        print(\"\\n⚠️  Could not load test result from new sweep (jobs may still be running)\")\n",
    "\n",
