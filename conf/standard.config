/*
========================================================================================
    Standard Configuration - For General Use with Conda/Containers
========================================================================================
    This configuration is designed for:
    - Local workstations
    - Cloud environments
    - HPC systems without module loading
    
    Uses only conda environments or containers (Singularity/Docker)
========================================================================================
*/

// Define scratch/cache directory
def scratch_dir = System.getenv("VSC_SCRATCH_VO_USER") ?: System.getenv("VSC_SCRATCH") ?: "${System.getenv("HOME")}/scratch"

// Local executor (can be overridden by profiles)
executor {
    name = 'local'
    cpus = 8
    memory = '64 GB'  // Increased for GPU workloads like RandomBarcodes
}

// Process-specific configurations
process {
    // Default resources for all processes
    cpus = 2
    memory = '8 GB'
    time = '4h'
    
    // GPU-intensive processes
    withName: 'QUIK_BARCODE_CALLING' {
        cpus = 2
        memory = '32 GB'
        time = '4h'
        containerOptions = '--nv'  // Ensure GPU access in Singularity
        // GPU selection via environment variable (0 = first GPU)
        // To use specific GPU: set CUDA_VISIBLE_DEVICES in env block
    }
    
    withName: 'RANDOMBARCODES' {
        cpus = 2
        memory = '32 GB'
        time = '4h'
        containerOptions = '--nv'  // Ensure GPU access in Singularity
        // GPU selection via environment variable (0 = first GPU)
        // To use specific GPU: set CUDA_VISIBLE_DEVICES in env block
    }
    
    // Medium-intensity processes
    withName: 'COLUMBA_BUILD|COLUMBA_ALIGN' {
        cpus = 4
        memory = '16 GB'
        time = '2h'
    }
}

// Environment variables
env {
    APPTAINER_TMPDIR = "$scratch_dir/.apptainer/tmp"
    APPTAINER_CACHEDIR = "$scratch_dir/.apptainer/cache"
    SINGULARITY_CACHEDIR = "$scratch_dir/singularity"
    NXF_SINGULARITY_CACHEDIR = "$scratch_dir/.apptainer/cache"
    CONDA_PKGS_DIRS = "$scratch_dir/conda_pkgs"
    NXF_CONDA_CACHEDIR = "$scratch_dir/conda_cache"
    CONDA_ENVS_PATH = "$scratch_dir/conda_envs"
    TMPDIR = "$scratch_dir/tmp"
    CONDA_TMPDIR = "$scratch_dir/tmp"
    
    // GPU Control (uncomment to use specific GPU)
    // CUDA_VISIBLE_DEVICES = '0'           // Use only GPU 0
    // CUDA_VISIBLE_DEVICES = '0,1'         // Use GPUs 0 and 1
    // CUDA_VISIBLE_DEVICES = ''            // Hide all GPUs (CPU only)
}

// Conda configuration
conda {
    enabled = false  // Enable via profile
    useMamba = true  // Use mamba for faster dependency resolution
    cacheDir = "$scratch_dir/conda_cache"
}

// Singularity configuration
singularity {
    enabled = false  // Enable via profile
    autoMounts = true
    runOptions = '--nv'  // Enable GPU support
    cacheDir = "$scratch_dir/singularity"
}

// Docker configuration
docker {
    enabled = false  // Enable via profile
    runOptions = '--gpus all'  // Enable GPU support
    temp = 'auto'
}

