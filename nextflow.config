/*
========================================================================================
    Barcode Calling Benchmark Pipeline - Main Configuration
========================================================================================
    Author: Franco Alexander Poma Soto
    Description: Nextflow pipeline for benchmarking barcode calling tools
    Version: 2.0.0
========================================================================================
*/

// Import base configuration (process resources, reporting)
includeConfig 'conf/base.config'

// Import module/process-specific configuration
includeConfig 'conf/modules.config'

/*
========================================================================================
    Pipeline Parameters
========================================================================================
*/

params {
    // =====================
    // Tool Selection
    // =====================
    tool = "quik"  // Options: "quik", "randombarcodes", "columba"
    
    // =====================
    // Input/Output
    // =====================
    barcode_file = null         // Path to barcode file
    r1_fastq     = null         // Path to R1 FASTQ
    r2_fastq     = null         // Path to R2 FASTQ
    sample_id    = "test_sample"
    outdir       = "./results"
    
    // Ground truth for precision/recall calculation
    ground_truth = null         // Optional: ground truth barcode assignments
    
    // =====================
    // Common Parameters
    // =====================
    barcode_length = 36
    
    // =====================
    // QUIK Parameters
    // =====================
    barcode_start       = 0
    strategy            = "4_7_mer_gpu_v1"
    distance_measure    = "SEQUENCE_LEVENSHTEIN"
    rejection_threshold = 3
    
    // =====================
    // RandomBarcodes Parameters
    // =====================
    n_barcodes = null           // Number of barcodes (auto-detected if null)
    ntriage    = 5000           // Triage size
    nthresh    = 3              // Distance threshold
    gpus       = 1              // Number of GPUs
    
    // =====================
    // Columba Parameters
    // =====================
    columba_repo       = null   // Path to Columba repository (null = auto-clone)
    identity_threshold = 72     // Minimum identity threshold (-I parameter)
    barcode_window     = null   // Barcode window (-T parameter, e.g., "0-36")
    
    // =====================
    // Advanced Options
    // =====================
    singularity_pull_docker_container = false
}

/*
========================================================================================
    Execution Profiles
========================================================================================
    Supported profiles:
    
    1. local,singularity - Local execution with Singularity containers
       - Uses pre-built Columba container at containers_backup/columba_build.sif
       - Ideal for testing and reproducibility
       - Does NOT require columba_repo parameter
    
    2. slurm - HPC execution with SLURM scheduler and HPC modules
       - Uses HPC modules (CMake, GCCcore) for building/running Columba
       - Requires columba_repo parameter pointing to Columba source directory
       - Recommended for production benchmarks on HPC clusters
    
    Examples:
    - Local with Singularity:  nextflow run main.nf -profile local,singularity ...
    - SLURM with HPC modules:  nextflow run main.nf -profile slurm ...
========================================================================================
*/

profiles {
    
    // ===========================================
    // Singularity Profile (for local execution)
    // ===========================================
    
    singularity {
        def scratch_dir = System.getenv("VSC_SCRATCH_VO_USER") ?: System.getenv("VSC_SCRATCH") ?: "${System.getenv("HOME")}/scratch"
        conda.enabled = false
        singularity.enabled = true
        singularity.autoMounts = true
        singularity.cacheDir = "$scratch_dir/singularity"
        singularity.runOptions = '--nv'
    }
    
    // ===========================================
    // Executor Profiles (Schedulers)
    // ===========================================
    
    local {
        includeConfig 'conf/executors/local.config'
    }
    
    slurm {
        includeConfig 'conf/executors/slurm.config'
    }
}

/*
========================================================================================
    Manifest
========================================================================================
*/

manifest {
    name            = 'barcode-calling-benchmark'
    author          = 'Your Name'
    homePage        = 'https://github.com/OncoRNALab/BarcodeCalling_benchmark.git'
    description     = 'Nextflow pipeline for benchmarking barcode calling algorithms'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=21.10.3'
    version         = '2.0.0'
}
