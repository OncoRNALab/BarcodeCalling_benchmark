/*
========================================================================================
    PBS/Torque Executor Configuration
========================================================================================
    Generic PBS/Torque scheduler configuration
    For HPC-specific settings (module loading, etc.), use institutional configs
========================================================================================
*/

// Define scratch directory for caching
def scratch_dir = System.getenv("VSC_SCRATCH_VO_USER") ?: 
                  System.getenv("VSC_SCRATCH") ?: 
                  "${System.getenv("HOME")}/scratch"

// PBS executor settings
executor {
    name = 'pbs'
    queueSize = 20
    submitRateLimit = '5/1min'
    pollInterval = '30sec'
}

// Load PyTorch module for all PBS jobs  
// This will be inserted into the PBS script
process {
    beforeScript = 'module load PyTorch-bundle/2.1.2-foss-2023a-CUDA-12.1.1 2>/dev/null || true'
}

// Environment variables for all processes
env {
    APPTAINER_TMPDIR = "$scratch_dir/.apptainer/tmp"
    APPTAINER_CACHEDIR = "$scratch_dir/.apptainer/cache"
    SINGULARITY_CACHEDIR = "$scratch_dir/singularity"
    NXF_SINGULARITY_CACHEDIR = "$scratch_dir/.apptainer/cache"
    CONDA_PKGS_DIRS = "$scratch_dir/conda_pkgs"
    NXF_CONDA_CACHEDIR = "$scratch_dir/conda_cache"
    CONDA_ENVS_PATH = "$scratch_dir/conda_envs"
    TMPDIR = "$scratch_dir/tmp"
    CONDA_TMPDIR = "$scratch_dir/tmp"
}

// Process configurations for PBS
process {
    // Stage settings for better performance
    stageInMode = "symlink"
    stageOutMode = "rsync"
    
    // Default PBS cluster options
    clusterOptions = { "-l nodes=1:ppn=${task.cpus}" }
    
    // GPU processes need GPU in cluster options and PyTorch module
    withLabel: use_gpu {
        // Load PyTorch with CUDA support on HPC (includes CUDA)
        beforeScript = 'module load PyTorch-bundle/2.1.2-foss-2023a-CUDA-12.1.1'
        
        // Request GPU in PBS
        // Ensure ppn is at least the number of GPUs (1 CPU per GPU minimum)
        clusterOptions = { 
            def gpus = params.gpus ?: 1
            def cpus = Math.max(task.cpus, gpus)
            "-l nodes=1:ppn=${cpus}:gpus=${gpus}" 
        }
    }
    
    // ========================================
    // CRITICAL: RandomBarcodes PBS Override
    // ========================================
    // RandomBarcodes MUST use HPC modules on PBS, never conda/containers
    // This null override ensures that even if conda/container directives are
    // accidentally added to the process definition or modules.config,
    // they will be nullified when running on PBS.
    // 
    // For other executors (local), see conf/modules.config for conda/container settings.
    withName: 'RANDOMBARCODES' {
        conda = null
        container = null
    }
    
    // QUIK needs CMake in addition to CUDA (from PyTorch-bundle)
    withName: 'QUIK_BARCODE_CALLING' {
        beforeScript = 'module load PyTorch-bundle/2.1.2-foss-2023a-CUDA-12.1.1 CMake/3.29.3-GCCcore-13.3.0 2>/dev/null || true'
    }
}

// ========================================
// Container Engine Configuration
// ========================================
// PBS executor supports both conda and singularity when used with profiles
// The enabling is controlled by profiles (singularity, conda)
// These blocks only provide configuration settings

// Conda configuration for PBS
conda {
    cacheDir = "$scratch_dir/conda_cache"
}

// Singularity configuration for PBS
singularity {
    autoMounts = true
    runOptions = '--nv'
    cacheDir = "$scratch_dir/singularity"
}

// Docker configuration for PBS
docker {
    enabled = false
}
