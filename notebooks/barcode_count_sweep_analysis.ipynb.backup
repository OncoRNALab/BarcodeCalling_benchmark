    "# Configuration\n",
    "TOOLS = {\n",
    "    'randombarcodes': {\n",
    "        'name': 'RandomBarcodes',\n",
    "        'thresholds': [5, 6, 7, 8, 9],\n",
    "        'threshold_param': 'nthresh',\n",
    "        'fixed_params': {'ntriage': 100, 'gpus': 1}\n",
    "    },\n",
    "    'quik': {\n",
    "        'name': 'QUIK',\n",
    "        'thresholds': [5, 6, 7, 8, 9],\n",
    "        'threshold_param': 'rejection_threshold',\n",
    "        'fixed_params': {'strategy': '4_mer_gpu_v4', 'gpus': 1}\n",
    "    },\n",
    "    'columba': {\n",
    "        'name': 'Columba',\n",
    "        'thresholds': [77, 78, 79, 80, 81, 82],\n",
    "        'threshold_param': 'identity_threshold',\n",
    "        'fixed_params': {'cpus': 4}\n",
    "    }\n",
    "}\n",
    "\n",
    "BARCODE_COUNTS = [21000, 42000, 85000]\n",
    "BARCODE_LENGTHS = [28, 36]\n",
    "TOTAL_READS = 200000\n",
    "\n",
    "RESULTS_PATH = Path(\"/user/gent/446/vsc44685/ScratchVO_dir/barcalling_review/BarCall_benchmark/parameter_sweeps_barcode_count\")\n",
    "\n",
    "# Previous experiment paths for 21K results\n",
    "PREVIOUS_RESULTS_28NT = Path(\"/user/gent/446/vsc44685/ScratchVO_dir/barcalling_review/results_sweep/results_28nt/summaries/paramsweep_all.csv\")\n",
    "PREVIOUS_RESULTS_36NT = Path(\"/user/gent/446/vsc44685/ScratchVO_dir/barcalling_review/results_sweep/results_36nt/summaries/all_corrected_metrics.csv\")\n",
    "\n",
    "print(\"Configuration loaded:\")\n",
    "\n",
    "print(f\"  Tools: {list(TOOLS.keys())}\")print(f\"  Previous 21K results (36nt): {PREVIOUS_RESULTS_36NT}\")\n",
    "\n",
    "print(f\"  Barcode counts: {BARCODE_COUNTS}\")print(f\"  Previous 21K results (28nt): {PREVIOUS_RESULTS_28NT}\")\n",
    "\n",
    "print(f\"  Barcode lengths: {BARCODE_LENGTHS}\")print(f\"  New results path (42K/85K): {RESULTS_PATH}\")"
   ]
