/*
========================================================================================
    Local Executor Configuration
========================================================================================
    For running on a single machine (workstation, laptop, or within HPC login node)
========================================================================================
*/

// Define scratch/cache directory
def scratch_dir = System.getenv("VSC_SCRATCH_VO_USER") ?: 
                  System.getenv("VSC_SCRATCH") ?: 
                  "${System.getenv("HOME")}/scratch"

// Local executor
executor {
    name = 'local'
    cpus = 8
    memory = '64 GB'
}

// Environment variables
env {
    APPTAINER_TMPDIR = "$scratch_dir/.apptainer/tmp"
    APPTAINER_CACHEDIR = "$scratch_dir/.apptainer/cache"
    SINGULARITY_CACHEDIR = "$scratch_dir/singularity"
    NXF_SINGULARITY_CACHEDIR = "$scratch_dir/.apptainer/cache"
    CONDA_PKGS_DIRS = "$scratch_dir/conda_pkgs"
    NXF_CONDA_CACHEDIR = "$scratch_dir/conda_cache"
    CONDA_ENVS_PATH = "$scratch_dir/conda_envs"
    TMPDIR = "$scratch_dir/tmp"
    CONDA_TMPDIR = "$scratch_dir/tmp"
    
    // GPU Control (uncomment to restrict GPU visibility)
    // CUDA_VISIBLE_DEVICES = '0'  // Use only GPU 0
}

// GPU access for containers (local execution)
process {
    withLabel: use_gpu {
        // Singularity GPU access
        containerOptions = { 
            workflow.containerEngine == "singularity" || workflow.containerEngine == "apptainer" ? '--nv' : 
            workflow.containerEngine == "docker" ? '--gpus all' : 
            null 
        }
    }
}

// Note: Container engine configuration (singularity, docker, apptainer) and 
// conda configuration are handled by the respective profiles in nextflow.config
// Do not override them here to allow profile-based control
