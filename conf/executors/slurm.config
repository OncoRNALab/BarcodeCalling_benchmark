/*
========================================================================================
    SLURM Executor Configuration
========================================================================================
    Generic SLURM scheduler configuration
    For HPC-specific settings (module loading, queue names), use institutional configs
========================================================================================
*/

// Define scratch directory for caching
def scratch_dir = System.getenv("VSC_SCRATCH_VO_USER") ?: 
                  System.getenv("VSC_SCRATCH") ?: 
                  "${System.getenv("HOME")}/scratch"

// SLURM executor settings
executor {
    name = 'slurm'
    queueSize = 50
    submitRateLimit = '10/1min'
    pollInterval = '30sec'
}

// Environment variables for all processes
env {
    APPTAINER_TMPDIR = "$scratch_dir/.apptainer/tmp"
    APPTAINER_CACHEDIR = "$scratch_dir/.apptainer/cache"
    SINGULARITY_CACHEDIR = "$scratch_dir/singularity"
    NXF_SINGULARITY_CACHEDIR = "$scratch_dir/.apptainer/cache"
    CONDA_PKGS_DIRS = "$scratch_dir/conda_pkgs"
    NXF_CONDA_CACHEDIR = "$scratch_dir/conda_cache"
    CONDA_ENVS_PATH = "$scratch_dir/conda_envs"
    TMPDIR = "$scratch_dir/tmp"
    CONDA_TMPDIR = "$scratch_dir/tmp"
}

// Process configurations for SLURM
process {
    // Stage settings for better performance
    stageInMode = "symlink"
    stageOutMode = "rsync"
    
    // GPU processes need GPU allocation and PyTorch module
    withLabel: use_gpu {
        // Load PyTorch with CUDA support on HPC (includes CUDA) and CMake for QUIK compilation
        beforeScript = 'module load CMake/3.26.3-GCCcore-12.3.0 && module load PyTorch-bundle/2.1.2-foss-2023a-CUDA-12.1.1'
        
        // Cluster-specific GPU allocation - support multi-GPU via params.gpus
        // Using --gres=gpu:N is more reliable on UGent clusters for resource isolation
        clusterOptions = { 
            def gpus = params.gpus ?: 1
            def cpus = Math.max(task.cpus, gpus)
            "--gres=gpu:${gpus} --cpus-per-task=${cpus} --clusters=joltik,accelgor" + 
            (System.getenv("SBATCH_ACCOUNT") || System.getenv("SLURM_ACCOUNT") ? 
                " --account=" + (System.getenv("SBATCH_ACCOUNT") ?: System.getenv("SLURM_ACCOUNT")) : 
                "")
        }
        
        // Container GPU access
        containerOptions = { 
            workflow.containerEngine == "singularity" || workflow.containerEngine == "apptainer" ? '--nv' : null 
        }
    }
    
    // ========================================
    // CRITICAL: RandomBarcodes SLURM Override
    // ========================================
    // RandomBarcodes MUST use HPC modules on SLURM, never conda/containers
    // This null override ensures that even if conda/container directives are
    // accidentally added to the process definition or modules.config,
    // they will be nullified when running on SLURM.
    // 
    // For other executors (local), see conf/modules.config for conda/container settings.
    withName: 'RANDOMBARCODES' {
        conda = null
        container = null
    }
    
    // ========================================
    // CRITICAL: Columba SLURM Override
    // ========================================
    // Columba MUST use HPC modules on SLURM, never conda/containers
    // This null override ensures conda directives from the module are disabled
    // when running on SLURM, forcing use of optimized HPC modules.
    //
    // For other executors (local), Columba uses conda environment from envs/columba.yml
    
    withName: 'COLUMBA_BUILD' {
        beforeScript = 'module load CMake/3.29.3-GCCcore-13.3.0'
        conda = null
        container = null
    }
    
    withName: 'COLUMBA_INDEX' {
        beforeScript = 'module load GCCcore/13.3.0'
        conda = null
        container = null
    }
    
    withName: 'COLUMBA_ALIGN' {
        beforeScript = 'module load GCCcore/13.3.0'
        conda = null
        container = null
    }
}

// Conda configuration for SLURM
// Note: conda.enabled is set by profile, we only configure options here
conda {
    useMamba = false
    cacheDir = "$scratch_dir/conda_cache"
}
