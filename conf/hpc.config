/*
========================================================================================
    HPC Configuration - For Institutional HPC with Module System
========================================================================================
    This configuration is optimized for HPC systems that use environment modules
    (like VSC HPC). It includes:
    - Module loading via beforeScript directives
    - PBS/Torque scheduler settings
    - GPU resource allocation
========================================================================================
*/

// Define scratch directory for caching
def scratch_dir = System.getenv("VSC_SCRATCH_VO_USER") ?: System.getenv("VSC_SCRATCH") ?: "${System.getenv("HOME")}/scratch"

// PBS executor settings
executor {
    name = 'pbs'
    queueSize = 20
    submitRateLimit = '5/1min'
    pollInterval = '30sec'
}

// Environment variables for all processes
env {
    APPTAINER_TMPDIR = "$scratch_dir/.apptainer/tmp"
    APPTAINER_CACHEDIR = "$scratch_dir/.apptainer/cache"
    SINGULARITY_CACHEDIR = "$scratch_dir/singularity"
    NXF_SINGULARITY_CACHEDIR = "$scratch_dir/.apptainer/cache"
    CONDA_PKGS_DIRS = "$scratch_dir/conda_pkgs"
    NXF_CONDA_CACHEDIR = "$scratch_dir/conda_cache"
    CONDA_ENVS_PATH = "$scratch_dir/conda_envs"
    TMPDIR = "$scratch_dir/tmp"
    CONDA_TMPDIR = "$scratch_dir/tmp"
}

// Process configurations for HPC
process {
    // Stage settings for better performance
    stageInMode = "symlink"
    stageOutMode = "rsync"
    
    // Default PBS cluster options
    // Note: walltime and mem are automatically handled by Nextflow's PBS executor
    // from task.time and task.memory directives in base.config
    clusterOptions = { "-l nodes=1:ppn=${task.cpus}" }
    
    // QUIK: Load CUDA and CMake modules, request GPU
    withName: 'QUIK_BARCODE_CALLING' {
        beforeScript = 'module load CUDA/12.6.0 CMake/3.29.3-GCCcore-13.3.0 2>/dev/null || true'
        clusterOptions = { "-l nodes=1:ppn=${task.cpus}:gpus=1" }
    }
    
    // RandomBarcodes: Request GPU
    withName: 'RANDOMBARCODES' {
        clusterOptions = { "-l nodes=1:ppn=${task.cpus}:gpus=1" }
    }
    
    // Columba Build: Load CMake module
    withName: 'COLUMBA_BUILD' {
        beforeScript = 'module load CMake/3.29.3-GCCcore-13.3.0 2>/dev/null || true'
    }
    
    // Columba Index: Load GCC module for runtime libraries
    withName: 'COLUMBA_INDEX' {
        beforeScript = 'module load GCCcore/13.3.0 2>/dev/null || true'
    }
    
    // Columba Align: Load GCC module for runtime libraries
    withName: 'COLUMBA_ALIGN' {
        beforeScript = 'module load GCCcore/13.3.0 2>/dev/null || true'
    }
}

// Singularity configuration for HPC
singularity {
    enabled = false  // Enable via profile
    autoMounts = true
    cacheDir = "$scratch_dir/singularity"
}

// Conda configuration for HPC
conda {
    enabled = true
    useMamba = false
    // Cache conda environments in scratch to avoid home directory quota issues
    cacheDir = "$scratch_dir/conda_cache"
}

