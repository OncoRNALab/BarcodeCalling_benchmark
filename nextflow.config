/*
========================================================================================
    Barcode Calling Benchmark Pipeline - Main Configuration
========================================================================================
    Author: Franco Alexander Poma Soto
    Description: Nextflow pipeline for benchmarking barcode calling tools
    Version: 2.0.0
========================================================================================
*/

// Import base configuration (process resources, reporting)
includeConfig 'conf/base.config'

// Import module/process-specific configuration
includeConfig 'conf/modules.config'

/*
========================================================================================
    Pipeline Parameters
========================================================================================
*/

params {
    // =====================
    // Tool Selection
    // =====================
    tool = "quik"  // Options: "quik", "randombarcodes", "columba"
    
    // =====================
    // Input/Output
    // =====================
    barcode_file = null         // Path to barcode file
    r1_fastq     = null         // Path to R1 FASTQ
    r2_fastq     = null         // Path to R2 FASTQ
    sample_id    = "test_sample"
    outdir       = "./results"
    
    // Ground truth for precision/recall calculation
    ground_truth = null         // Optional: ground truth barcode assignments
    
    // =====================
    // Common Parameters
    // =====================
    barcode_length = 36
    
    // =====================
    // QUIK Parameters
    // =====================
    barcode_start       = 0
    strategy            = "4_7_mer_gpu_v1"
    distance_measure    = "SEQUENCE_LEVENSHTEIN"
    rejection_threshold = 3
    
    // =====================
    // RandomBarcodes Parameters
    // =====================
    n_barcodes = null           // Number of barcodes (auto-detected if null)
    ntriage    = 5000           // Triage size
    nthresh    = 3              // Distance threshold
    gpus       = 1              // Number of GPUs
    
    // =====================
    // Columba Parameters
    // =====================
    columba_repo       = null   // Path to Columba repository (null = auto-clone)
    identity_threshold = 72     // Minimum identity threshold (-I parameter)
    barcode_window     = null   // Barcode window (-T parameter, e.g., "0-36")
    
    // =====================
    // Advanced Options
    // =====================
    singularity_pull_docker_container = false
}

/*
========================================================================================
    Execution Profiles
========================================================================================
    IMPORTANT: Profile order matters!
    
    When combining profiles, list the environment profile FIRST, then the executor:
    ✅ Correct:   -profile singularity,pbs
    ✅ Correct:   -profile conda,slurm
    ❌ Wrong:     -profile pbs,singularity  (executor config may override environment)
    
    Why? Later profiles can override earlier settings. Environment profiles
    (singularity, conda, docker) set conda.enabled and singularity.enabled flags.
    If the executor profile loads first and has these flags, it may prevent the
    environment profile from taking effect.
    
    Examples:
    - Local with Singularity:  -profile singularity,local  (or just: singularity)
    - PBS with Conda:          -profile conda,pbs
    - PBS with Singularity:    -profile singularity,pbs
    - SLURM with containers:   -profile singularity,slurm
========================================================================================
*/

profiles {
    
    // ===========================================
    // Container Engine Profiles  
    // ===========================================
    
    conda {
        conda.enabled = true
    }
    
    singularity {
        def scratch_dir = System.getenv("VSC_SCRATCH_VO_USER") ?: System.getenv("VSC_SCRATCH") ?: "${System.getenv("HOME")}/scratch"
        conda.enabled = false
        singularity.enabled = true
        singularity.autoMounts = true
        singularity.cacheDir = "$scratch_dir/singularity"
        singularity.runOptions = '--nv'
    }
    
    apptainer {
        conda.enabled = false
        apptainer.enabled = true
        apptainer.autoMounts = true
    }
    
    docker {
        conda.enabled = false
        docker.enabled = true
    }
    
    // ===========================================
    // Executor Profiles (Schedulers)
    // ===========================================
    
    local {
        includeConfig 'conf/executors/local.config'
    }
    
    pbs {
        includeConfig 'conf/executors/pbs.config'
    }
    
    slurm {
        includeConfig 'conf/executors/slurm.config'
    }
    
    // ===========================================
    // Testing Profile
    // ===========================================
    
    test {
        params.outdir = "./test_results"
        process {
            withLabel: 'use_gpu|process_high|process_high_memory' {
                cpus   = 1
                memory = 4.GB
                time   = 30.min
            }
        }
    }
}

/*
========================================================================================
    Manifest
========================================================================================
*/

manifest {
    name            = 'barcode-calling-benchmark'
    author          = 'Your Name'
    homePage        = 'https://github.com/OncoRNALab/BarcodeCalling_benchmark.git'
    description     = 'Nextflow pipeline for benchmarking barcode calling algorithms'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=21.10.3'
    version         = '2.0.0'
}
