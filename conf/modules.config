/*
========================================================================================
    Module/Process-Specific Configuration
========================================================================================
    Per-process settings that are independent of executor/HPC
========================================================================================
*/

process {
    
    // ========================================
    // QUIK Barcode Calling
    // ========================================
    withName: 'QUIK_BARCODE_CALLING' {
        // Resource label (defined in base.config)
        label = 'use_gpu'
        
        // Container is defined in the module itself
        // Process-specific environment variables
        // (GPU allocation handled by executor config)
    }
    
    // ========================================
    // RandomBarcodes
    // ========================================
    withName: 'RANDOMBARCODES' {
        label = 'use_gpu'
        
        // Container and conda for LOCAL execution
        // These are overridden to null in conf/executors/pbs.config
        // to force HPC module usage on PBS
        conda = "${projectDir}/envs/randombarcodes.yml"
        container = 'docker://pytorch/pytorch:2.1.0-cuda11.8-cudnn8-runtime'
    }
    
    // ========================================
    // Columba Build
    // ========================================
    withName: 'COLUMBA_BUILD' {
        label = 'process_medium'
        conda = "${projectDir}/envs/columba.yml"
    }
    
    // ========================================
    // Columba Index
    // ========================================
    withName: 'COLUMBA_INDEX' {
        label = 'process_low'
    }
    
    // ========================================
    // Columba Align
    // ========================================
    withName: 'COLUMBA_ALIGN' {
        label = 'process_high_memory'
    }
    
    // ========================================
    // Barcode to FASTA Conversion
    // ========================================
    withName: 'BARCODE_TO_FASTA' {
        label = 'process_single'
    }
    
    // ========================================
    // Precision Calculation
    // ========================================
    withName: 'CALCULATE_PRECISION' {
        label = 'process_low'
    }
    
    withName: 'CALCULATE_PRECISION_SAM' {
        label = 'process_low'
    }
}
